# Weaver Agents Environment Configuration
# Copy this file to .env and adjust variables.

# Database url for PostgreSQL + pgvector
DATABASE_URL=postgresql://user:password@localhost:5432/coastal_alpine_helpdesk

# Ollama local instance URL
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# WEAVER SECOPS: DO NOT PUT REAL VALUES HERE
# Copy this to .env and input your local edge credentials
MQTT_BROKER_URL=ssl://your-broker-ip:8883
MQTT_USER=weaver_edge_node
MQTT_PASSWORD=insert_secure_password
MAGICBAG_API_KEY=insert_key_here

